---
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Bridnext — De autenticación legacy a autenticación moderna. SSO + MFA con OIDC/OAuth 2.0 para JDE, SAP, PeopleSoft y más.',
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/Bridnext_icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style>
      html { scroll-behavior: smooth; }
      ::selection { background-color: #599E9F; color: white; }
    </style>
  </head>
  <body class="font-sans bg-white text-bn-navy antialiased overflow-x-hidden">
    <slot />
  </body>
</html>
