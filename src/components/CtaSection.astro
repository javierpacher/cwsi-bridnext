---
---
<section id="contacto" class="py-24 bg-bn-navy relative overflow-hidden">

  <!-- Background decoration -->
  <div
    class="absolute inset-0 opacity-20"
    style="background-image: radial-gradient(circle, rgba(255,255,255,0.12) 1px, transparent 1px); background-size: 28px 28px;"
  ></div>
  <svg class="absolute top-0 left-0 w-2/3 max-w-xl opacity-70 pointer-events-none" viewBox="0 0 700 400" fill="none" aria-hidden="true">
    <path d="M-100 60 C 80 -40 280 180 480 100 C 680 20 780 180 980 100 L980-200 L-100-200Z" fill="#4ade80" opacity="0.10"/>
    <path d="M-100 120 C 60  20 260 240 460 160 C 660 80 780 240 980 160 L980-200 L-100-200Z" fill="#14b8a6" opacity="0.10"/>
  </svg>
  <svg class="absolute bottom-0 right-0 w-2/3 max-w-xl opacity-70 rotate-180 pointer-events-none" viewBox="0 0 700 400" fill="none" aria-hidden="true">
    <path d="M-100 60 C 80 -40 280 180 480 100 C 680 20 780 180 980 100 L980-200 L-100-200Z" fill="#a3e635" opacity="0.08"/>
    <path d="M-100 120 C 60  20 260 240 460 160 C 660 80 780 240 980 160 L980-200 L-100-200Z" fill="#4ade80" opacity="0.10"/>
  </svg>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Logo mark -->
    <div class="flex justify-center mb-8">
      <img src="/Bridnext_icon.png" alt="Bridnext" class="h-16 w-auto opacity-90" />
    </div>

    <h2 class="text-4xl sm:text-5xl font-black text-white leading-tight">
      ¿Listo para modernizar<br/>tu autenticación?
    </h2>
    <p class="mt-6 text-lg text-white/55 leading-relaxed max-w-xl mx-auto">
      Implementa SSO + MFA en tu JDE en semanas. Sin reemplazar licencias. Sin tocar tu infraestructura existente.
    </p>

    <!-- CTAs -->
    <div class="flex justify-center mt-10">
      <a
        href="mailto:contacto@bridnext.com"
        class="inline-flex items-center justify-center gap-2 bg-bn-teal hover:bg-bn-teal-light text-white font-semibold px-9 py-4 rounded-xl transition-all duration-200 shadow-xl shadow-bn-teal/25 text-base"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Solicitar Demo
      </a>
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap justify-center gap-6 mt-14 text-sm text-white/35 font-medium">
      {[
        '🔐 Zero-Trust Security',
        '☁️ Multi-Cloud',
        '⚡ Deploy en semanas',
        '📋 Audit compliant',
      ].map(b => (
        <span class="flex items-center gap-1.5">{b}</span>
      ))}
    </div>

  </div>
</section>
