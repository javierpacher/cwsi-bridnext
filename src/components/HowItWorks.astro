---
const steps = [
  {
    n: '01',
    title: 'Usuario accede a JDE',
    desc: 'El filtro del conector detecta que no existe sesión activa y captura la URL de retorno.',
    tag: 'Connector',
    color: 'bg-bn-navy text-white',
  },
  {
    n: '02',
    title: 'Redirige al Bridge-Service',
    desc: 'SSO Servlet redirige al backend de Bridnext con la Instancia JDE y URL de retorno.',
    tag: 'Connector → Backend',
    color: 'bg-bn-teal text-white',
  },
  {
    n: '03',
    title: 'Autenticación en el IdP',
    desc: 'El backend redirige al IdP (OIDC). El usuario se autentica: MFA (TOTP/Push), biometría o login federado con Microsoft/Google.',
    tag: 'IdP',
    color: 'bg-bn-green/90 text-bn-navy',
  },
  {
    n: '04',
    title: 'Backend crea el Handoff JWT',
    desc: 'Valida el Access Token del IdP. Verifica tenant, instancia, mapping de usuario y estado ENABLED. Emite un JWT firmado (RS256) con TTL de ~60s.',
    tag: 'Backend',
    color: 'bg-bn-teal text-white',
  },
  {
    n: '05',
    title: 'Conector consume el token',
    desc: 'SSO Servlet valida el JWT (JWKS remoto), registra el JTI en el servicio anti-replay central y construye el token de sesión JDE local.',
    tag: 'Connector',
    color: 'bg-bn-navy text-white',
  },
  {
    n: '06',
    title: 'Acceso garantizado',
    desc: 'La sesión JDE se crea con el perfil RBAC existente del usuario. Las contraseñas locales quedan obsoletas para el flujo diario.',
    tag: 'JDE Session',
    color: 'bg-bn-lime text-bn-navy',
  },
];

const securityPoints = [
  { label: 'RS256 + JWKS remoto',   desc: 'Firma asimétrica, claves en el backend' },
  { label: 'Short TTL (~60s)',       desc: 'Tokens que expiran antes de poder reusarse' },
  { label: 'Central Anti-replay',   desc: 'JTI + Redis, con grace period de skew' },
  { label: 'Return URL Allowlist',  desc: 'Solo destinos pre-validados por tenant' },
  { label: 'IdP user ↔ JDE Mapping', desc: 'Identidad IdP mapeada a usuario local' },
  { label: 'Audience por instancia', desc: 'Token sólo válido para su JDE host' },
];
---

<section id="como-funciona" class="py-24 bg-bn-gray relative overflow-hidden">

  <!-- Soft wave top -->
  <div class="absolute top-0 left-0 right-0 h-24 bg-gradient-to-b from-white to-transparent pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block bg-bn-teal text-white text-xs font-semibold tracking-widest uppercase px-4 py-1.5 rounded-full mb-5">
        ¿Cómo Funciona?
      </span>
      <h2 class="text-4xl sm:text-5xl font-black text-bn-navy leading-tight">
        Flujo SSO en 6 pasos
      </h2>
      <p class="mt-5 text-lg text-bn-navy/55 max-w-2xl mx-auto">
        Del clic del usuario a la sesión JDE en segundos, con validación multi-capa
        y sin comprometer la seguridad.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-16">
      {steps.map((s, i) => (
        <div class="relative bg-white rounded-2xl border border-bn-navy/8 p-6 shadow-sm hover:shadow-md transition-shadow duration-200">
          <!-- Step number -->
          <span class="text-5xl font-black text-bn-navy/6 absolute top-4 right-5 leading-none select-none">
            {s.n}
          </span>
          <!-- Tag -->
          <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-md mb-4 ${s.color}`}>
            {s.tag}
          </span>
          <!-- Content -->
          <h3 class="text-base font-bold text-bn-navy mb-2">{s.title}</h3>
          <p class="text-sm text-bn-navy/55 leading-relaxed">{s.desc}</p>
          <!-- Connector line -->
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute -right-3 top-1/2 -translate-y-1/2 w-6 text-center text-bn-teal z-10">→</div>
          )}
        </div>
      ))}
    </div>

    <!-- Handoff JWT pre-check -->
    <div class="bg-bn-navy rounded-2xl p-8 mb-8">
      <div class="flex items-start gap-4 mb-6">
        <span class="text-2xl">🔒</span>
        <div>
          <h3 class="text-lg font-bold text-white">Handoff JWT — Pre-Check</h3>
          <p class="text-sm text-white/50 mt-1">Todas las condiciones deben ser verdaderas. Un fallo → JWT DENEGADO.</p>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          '✅ Tenant ID válido (IdP match vs. Bridnext)',
          '✅ Verificación de instancia (host local)',
          '✅ Verificación de usuario (IdP user vs. Mapping)',
          '✅ Permiso de conexión (status = ENABLED)',
        ].map(check => (
          <div class="bg-white/8 border border-white/10 rounded-xl px-4 py-3 text-sm font-medium text-white/80">
            {check}
          </div>
        ))}
      </div>
    </div>

    <!-- Security model -->
    <div>
      <h3 class="text-lg font-bold text-bn-navy mb-5 flex items-center gap-2">
        <span class="text-bn-teal">🛡</span> Security & Trust Model
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {securityPoints.map(p => (
          <div class="flex items-start gap-3 bg-white border border-bn-navy/8 rounded-xl px-5 py-4 shadow-sm">
            <span class="text-bn-teal font-black text-lg leading-none mt-0.5">·</span>
            <div>
              <p class="text-sm font-semibold text-bn-navy">{p.label}</p>
              <p class="text-xs text-bn-navy/50 mt-0.5">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
